+// DAV HACK
+//-------------------------------------------------
+//  clear_temporary_quanta - clear all temporary
+//  quanta and reset to minimum
+//-------------------------------------------------
+
+void device_scheduler::clear_temporary_quanta()
+{
+	quantum_slot *next;
+	for (quantum_slot *quant = m_quantum_list.first(); quant != nullptr; quant = next)
+	{
+		next = quant->next();
+		if (!quant->m_expire.is_never())
+			m_quantum_allocator.reclaim(m_quantum_list.detach(*quant));
+	}
+	
+	if (m_quantum_list.empty())
+		add_quantum(attotime(0, m_quantum_minimum), attotime::never);
+
+	m_suspend_changes_pending = true;
+	rebuild_execute_list();
+}
+
+//-------------------------------------------------
+//  canonicalize_timer_order - netplay rollback hook.
+//  Normalizes active timers so a netplay forward run
+//  is byte-identical to a rollback savestate load.
+//  This prevents desyncs between forward and rollback
+//  states using existing MAME save logic.
+//-------------------------------------------------
+
+void device_scheduler::canonicalize_timer_order()
+{
+	postload();
+}
+
+// END DAV HACK
 
